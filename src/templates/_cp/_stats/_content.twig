{% set groupId = craft.app.request.getParam('groupId') %}

<p style="font-size: 0.7rem; margin-top: 0;"><strong>{{ 'We track how many users accept, deny, or customize cookies to understand how cookie consent impacts the data we see in our analytics tools. This helps identify discrepancies in expected vs. actual user counts, evaluate the effectiveness of design changes to the cookie banner, and quickly detect shifts in user behavior after website updates.'|t }}</strong></p>

{% if cookiesPresent|length %}
    <div id="dashboard-grid" class="grid">
        <div class="item" data-colspan="3">
            <div class="front">
                <div class="pane">
                    <div class="body">
                        <h2 style="margin-bottom: 0;">{{ 'Percentage rates'|t }}</h2>
                        <p style="font-size: 0.7rem; margin-top: 0;">{{ 'Cookie statistics are being tracked since'|t }} {{ firstRecordDate }}</p>
                        {% include('_statik-cookie-banner/_cp/_widgets/_total_cookies.twig')|raw %}
                    </div>
                </div>
            </div>
        </div>
        <div class="item" data-colspan="3">
            <div class="widget">
                <div class="front">
                    <div class="pane bg-white" style="background: white;">
                        <div class="body">
                            {% include('_statik-cookie-banner/_cp/_widgets/_table.twig')|raw %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% else %}
    <div>{{ 'No data present in database yet'|t }}</div>
{% endif %}

{% set columnsVotes = [
    { name: '__slot:title', title: "Period per site" },
    { name: 'accepted', title: 'Accepted' },
    { name: 'denied', title: 'Denied' },
    { name: 'settings', title: "Settings" },
] %}
{% set actions = [] %}


{% if (groupId and (selectedSite and selectedSite.id > 0)) or not groupId %}
    {% set endpoint = '/admin/cookie-banner/statistics/table-view-site/' ~ selectedSite.id ?? '0' %}
{% else %}
    {% set endpoint = '/admin/cookie-banner/statistics/table-view-group/' ~ groupId %}
{% endif %}

{% js %}
    new Craft.VueAdminTable({
    container: '#cookie-table',
    columns: {{ columnsVotes|json_encode|raw }},
    tableDataEndpoint: "{{ endpoint }}" ,
    checkboxes:  0,
    allowMultipleSelections: false,
    perPage: 100,
    actions: {{ actions|json_encode|raw }},
    });
{% endjs %}
